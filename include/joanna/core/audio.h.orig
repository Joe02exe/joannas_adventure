#pragma once

#ifdef MIYOO_BUILD
#include <SDL_mixer.h>
#include <string>

namespace jo {

class SoundBuffer {
  public:
    SoundBuffer() : m_chunk(nullptr) {}

    ~SoundBuffer() {
        if (m_chunk)
            Mix_FreeChunk(m_chunk);
    }

    SoundBuffer(const SoundBuffer&) = delete;
    SoundBuffer& operator=(const SoundBuffer&) = delete;

    SoundBuffer(SoundBuffer&& o) noexcept : m_chunk(o.m_chunk) {
        o.m_chunk = nullptr;
    }

    SoundBuffer& operator=(SoundBuffer&& o) noexcept {
        if (this != &o) {
            if (m_chunk)
                Mix_FreeChunk(m_chunk);
            m_chunk = o.m_chunk;
            o.m_chunk = nullptr;
        }
        return *this;
    }

    bool loadFromFile(const std::string& filename) {
        if (m_chunk)
            Mix_FreeChunk(m_chunk);
        m_chunk = Mix_LoadWAV(filename.c_str());
        return m_chunk != nullptr;
    }

    Mix_Chunk* getChunk() const {
        return m_chunk;
    }

  private:
    Mix_Chunk* m_chunk;
};

class Sound {
  public:
    Sound() : m_chunk(nullptr), m_volume(128) {}

    explicit Sound(const SoundBuffer& buffer)
        : m_chunk(buffer.getChunk()), m_volume(128) {
        if (m_chunk)
            m_chunk->volume = m_volume;
    }

    void setBuffer(const SoundBuffer& buffer) {
        m_chunk = buffer.getChunk();
        if (m_chunk)
            m_chunk->volume = m_volume;
    }

    void play() {
        if (m_chunk) {
            Mix_PlayChannel(-1, m_chunk, 0);
        }
    }

    void stop() { /* Note: individual Sound stop not straightforward in
                     Mix_PlayChannel without tracking channel ID */
    }

    void setVolume(float volume) {
        m_volume = static_cast<int>(volume * 128.f / 100.f);
        if (m_chunk) {
            m_chunk->volume = m_volume;
        }
    }

  private:
    Mix_Chunk* m_chunk;
    int m_volume;
};

// Full Mix_Music-backed Music class for Miyoo
class Music {
  public:
    enum class Status { Stopped, Paused, Playing };

    Music()
        : m_music(nullptr), m_status(Status::Stopped), m_loop(true),
          m_volume(128) {}

    ~Music() {
        if (m_music) {
            Mix_HaltMusic();
            Mix_FreeMusic(m_music);
        }
    }

    // Non-copyable, but movable
    Music(const Music&) = delete;
    Music& operator=(const Music&) = delete;

    Music(Music&& o) noexcept
        : m_music(o.m_music), m_status(o.m_status), m_loop(o.m_loop),
          m_volume(o.m_volume) {
        o.m_music = nullptr;
    }

    Music& operator=(Music&& o) noexcept {
        if (this != &o) {
            if (m_music) {
                Mix_HaltMusic();
                Mix_FreeMusic(m_music);
            }
            m_music = o.m_music;
            m_status = o.m_status;
            m_loop = o.m_loop;
            m_volume = o.m_volume;
            o.m_music = nullptr;
        }
        return *this;
    }

    bool openFromFile(const std::string& filename) {
        if (m_music) {
            Mix_HaltMusic();
            Mix_FreeMusic(m_music);
            m_music = nullptr;
        }
        m_music = Mix_LoadMUS(filename.c_str());
        return m_music != nullptr;
    }

    void play() {
        if (!m_music)
            return;
        int loops = m_loop ? -1 : 0;
        Mix_VolumeMusic(m_volume);
        Mix_PlayMusic(m_music, loops);
        m_status = Status::Playing;
    }

    void pause() {
        Mix_PauseMusic();
        m_status = Status::Paused;
    }

    void stop() {
        Mix_HaltMusic();
        m_status = Status::Stopped;
    }

    void setLooping(bool loop) {
        m_loop = loop;
    }

    // volume: 0..100 mapped to 0..128
    void setVolume(float volume) {
        m_volume = static_cast<int>(volume * 128.f / 100.f);
        Mix_VolumeMusic(m_volume);
    }

    Status getStatus() const {
        if (m_status == Status::Playing && !Mix_PlayingMusic())
            return Status::Stopped;
        return m_status;
    }

  private:
    Mix_Music* m_music;
    Status m_status;
    bool m_loop;
    int m_volume;
};

} // namespace jo
#else
#include <SFML/Audio.hpp>

namespace jo {
using namespace sf;
}
#endif
